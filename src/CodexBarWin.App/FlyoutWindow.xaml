<Window x:Class="CodexBarWin.App.FlyoutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:CodexBarWin.App.Converters"
        Title="CodexBarWin"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        SizeToContent="Height"
        Width="360"
        WindowStartupLocation="Manual">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <conv:InverseBooleanToVisibilityConverter x:Key="InverseBoolToVis"/>
    </Window.Resources>

    <Border Background="{StaticResource BrushCardBackground}"
            BorderBrush="{StaticResource BrushBorder}"
            BorderThickness="1"
            CornerRadius="14"
            Margin="10"
            Padding="16">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" ShadowDepth="4" Opacity="0.4" Color="Black"/>
        </Border.Effect>

        <StackPanel>

            <!-- Header -->
            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="CodexBarWin" FontSize="15" FontWeight="Bold"
                           Foreground="{StaticResource BrushTextPrimary}" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="1" Text="{Binding StatusText}" FontSize="11"
                           Foreground="{StaticResource BrushTextSecondary}" VerticalAlignment="Center"/>
            </Grid>

            <!-- Tab toggle -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                <RadioButton GroupName="Tabs" Style="{StaticResource TabToggleButtonStyle}"
                             Content="Codex"
                             IsChecked="{Binding IsCodexTabSelected, Mode=TwoWay}"
                             Command="{Binding SelectCodexTabCommand}"/>
                <RadioButton GroupName="Tabs" Style="{StaticResource TabToggleButtonStyle}"
                             Content="Claude" Margin="6,0,0,0"
                             IsChecked="{Binding IsClaudeTabSelected, Mode=TwoWay}"
                             Command="{Binding SelectClaudeTabCommand}"/>
            </StackPanel>

            <!-- Codex tab -->
            <StackPanel Visibility="{Binding IsCodexTabSelected, Converter={StaticResource BoolToVis}}">

                <StackPanel Visibility="{Binding CodexHasData, Converter={StaticResource InverseBoolToVis}}"
                            Margin="0,4,0,8">
                    <TextBlock Text="データが見つかりませんでした" Foreground="{StaticResource BrushTextSecondary}"
                               FontSize="12" TextWrapping="Wrap"/>
                </StackPanel>

                <StackPanel Visibility="{Binding CodexHasData, Converter={StaticResource BoolToVis}}">

                    <TextBlock Text="{Binding CodexPlanText}" FontSize="11"
                               Foreground="{StaticResource BrushTextSecondary}" Margin="0,0,0,8"/>

                    <!-- Session (5h) -->
                    <TextBlock Text="セッション (5h)" FontSize="12" FontWeight="SemiBold"
                               Foreground="{StaticResource BrushTextPrimary}" Margin="0,0,0,4"/>
                    <ProgressBar Value="{Binding CodexSessionUsedPercent, Mode=OneWay}"
                                 Foreground="{Binding CodexSessionBarBrush}"
                                 Style="{StaticResource UsageProgressBarStyle}"/>
                    <Grid Margin="0,4,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding CodexSessionRemainingText}" FontSize="12"
                                   Foreground="{StaticResource BrushTextPrimary}"/>
                        <TextBlock Grid.Column="1" Text="{Binding CodexSessionResetText}" FontSize="11"
                                   Foreground="{StaticResource BrushTextSecondary}"/>
                    </Grid>

                    <!-- Weekly -->
                    <TextBlock Text="週間" FontSize="12" FontWeight="SemiBold"
                               Foreground="{StaticResource BrushTextPrimary}" Margin="0,0,0,4"/>
                    <ProgressBar Value="{Binding CodexWeeklyUsedPercent, Mode=OneWay}"
                                 Foreground="{Binding CodexWeeklyBarBrush}"
                                 Style="{StaticResource UsageProgressBarStyle}"/>
                    <Grid Margin="0,4,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding CodexWeeklyRemainingText}" FontSize="12"
                                   Foreground="{StaticResource BrushTextPrimary}"/>
                        <TextBlock Grid.Column="1" Text="{Binding CodexWeeklyResetText}" FontSize="11"
                                   Foreground="{StaticResource BrushTextSecondary}"/>
                    </Grid>

                    <!-- Tokens -->
                    <Border Background="{StaticResource BrushPanelBackground}" CornerRadius="8" Padding="10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="今日" FontSize="10" Foreground="{StaticResource BrushTextSecondary}" HorizontalAlignment="Center"/>
                                <TextBlock Text="{Binding CodexTokensTodayText}" FontSize="12" Foreground="{StaticResource BrushTextPrimary}" HorizontalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="7日" FontSize="10" Foreground="{StaticResource BrushTextSecondary}" HorizontalAlignment="Center"/>
                                <TextBlock Text="{Binding CodexTokens7dText}" FontSize="12" Foreground="{StaticResource BrushTextPrimary}" HorizontalAlignment="Center"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="30日" FontSize="10" Foreground="{StaticResource BrushTextSecondary}" HorizontalAlignment="Center"/>
                                <TextBlock Text="{Binding CodexTokens30dText}" FontSize="12" Foreground="{StaticResource BrushTextPrimary}" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </StackPanel>
            </StackPanel>

            <!-- Claude tab -->
            <StackPanel Visibility="{Binding IsClaudeTabSelected, Converter={StaticResource BoolToVis}}">

                <StackPanel Visibility="{Binding ClaudeHasData, Converter={StaticResource InverseBoolToVis}}"
                            Margin="0,4,0,8">
                    <TextBlock Text="データが見つかりませんでした" Foreground="{StaticResource BrushTextSecondary}"
                               FontSize="12" TextWrapping="Wrap"/>
                </StackPanel>

                <StackPanel Visibility="{Binding ClaudeHasData, Converter={StaticResource BoolToVis}}">

                    <!-- Exact percent-based usage (from claude.ai API via Claude Desktop cookies) -->
                    <StackPanel Visibility="{Binding ClaudePercentAvailable, Converter={StaticResource BoolToVis}}">

                        <!-- Current session -->
                        <TextBlock Text="現在のセッション" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{StaticResource BrushTextPrimary}" Margin="0,0,0,4"/>
                        <ProgressBar Value="{Binding ClaudeSessionUsedPercent, Mode=OneWay}"
                                     Foreground="{Binding ClaudeSessionBarBrush}"
                                     Style="{StaticResource UsageProgressBarStyle}"/>
                        <Grid Margin="0,4,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding ClaudeSessionPercentText}" FontSize="12"
                                       Foreground="{StaticResource BrushTextPrimary}"/>
                            <TextBlock Grid.Column="1" Text="{Binding ClaudeSessionResetText}" FontSize="11"
                                       Foreground="{StaticResource BrushTextSecondary}"/>
                        </Grid>

                        <!-- Weekly (all models) -->
                        <TextBlock Text="週間 (すべてのモデル)" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{StaticResource BrushTextPrimary}" Margin="0,0,0,4"/>
                        <ProgressBar Value="{Binding ClaudeWeeklyUsedPercent, Mode=OneWay}"
                                     Foreground="{Binding ClaudeWeeklyBarBrush}"
                                     Style="{StaticResource UsageProgressBarStyle}"/>
                        <Grid Margin="0,4,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="{Binding ClaudeWeeklyPercentText}" FontSize="12"
                                       Foreground="{StaticResource BrushTextPrimary}"/>
                            <TextBlock Grid.Column="1" Text="{Binding ClaudeWeeklyResetText}" FontSize="11"
                                       Foreground="{StaticResource BrushTextSecondary}"/>
                        </Grid>

                        <!-- Per-model weekly scoped limits (e.g. Fable) -->
                        <ItemsControl ItemsSource="{Binding ClaudeScopedLimits}" Margin="0,0,0,8">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,0,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding NameText}" FontSize="12"
                                                   Foreground="{StaticResource BrushTextSecondary}"/>
                                        <TextBlock Grid.Column="1" Text="{Binding PercentText}" FontSize="12"
                                                   Foreground="{StaticResource BrushTextPrimary}"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <!-- Token/cost roll-up - always shown; the only data available when the
                         claude.ai API is unreachable (PercentSource=Unavailable). -->
                    <Border Background="{StaticResource BrushPanelBackground}" CornerRadius="8" Padding="10" Margin="0,0,0,10">
                        <StackPanel>
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="直近5時間" FontSize="12" Foreground="{StaticResource BrushTextSecondary}"/>
                                <TextBlock Grid.Column="1" Text="{Binding ClaudeLast5HoursText}" FontSize="12" Foreground="{StaticResource BrushTextPrimary}"/>
                            </Grid>
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="今日" FontSize="12" Foreground="{StaticResource BrushTextSecondary}"/>
                                <TextBlock Grid.Column="1" Text="{Binding ClaudeTodayText}" FontSize="12" Foreground="{StaticResource BrushTextPrimary}"/>
                            </Grid>
                            <Grid Margin="0,0,0,6">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="7日" FontSize="12" Foreground="{StaticResource BrushTextSecondary}"/>
                                <TextBlock Grid.Column="1" Text="{Binding ClaudeLast7DaysText}" FontSize="12" Foreground="{StaticResource BrushTextPrimary}"/>
                            </Grid>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="30日" FontSize="12" Foreground="{StaticResource BrushTextSecondary}"/>
                                <TextBlock Grid.Column="1" Text="{Binding ClaudeLast30DaysText}" FontSize="12" Foreground="{StaticResource BrushTextPrimary}"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="{Binding ClaudeFallbackNoteText}" FontSize="10"
                               Foreground="{StaticResource BrushTextSecondary}" TextWrapping="Wrap"
                               Visibility="{Binding ClaudePercentAvailable, Converter={StaticResource InverseBoolToVis}}"/>
                </StackPanel>
            </StackPanel>

            <!-- Footer -->
            <Grid Margin="0,12,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="45秒ごとに自動更新" FontSize="10" Foreground="{StaticResource BrushTextSecondary}" VerticalAlignment="Center"/>
                <Button Grid.Column="1" Content="今すぐ更新" FontSize="11" Padding="8,3"
                        Command="{Binding RefreshNowCommand}"
                        Background="{StaticResource BrushPanelBackground}"
                        Foreground="{StaticResource BrushTextPrimary}"
                        BorderThickness="0"/>
            </Grid>

        </StackPanel>
    </Border>
</Window>
