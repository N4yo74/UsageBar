<Application x:Class="CodexBarWin.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             ShutdownMode="OnExplicitShutdown">
    <Application.Resources>

        <SolidColorBrush x:Key="BrushCardBackground" Color="#1E1E22"/>
        <SolidColorBrush x:Key="BrushPanelBackground" Color="#2A2A2E"/>
        <SolidColorBrush x:Key="BrushTrackBackground" Color="#38383D"/>
        <SolidColorBrush x:Key="BrushBorder" Color="#3A3A40"/>
        <SolidColorBrush x:Key="BrushTextPrimary" Color="#F2F2F3"/>
        <SolidColorBrush x:Key="BrushTextSecondary" Color="#9A9AA2"/>
        <SolidColorBrush x:Key="BrushAccent" Color="#5B8CFF"/>
        <SolidColorBrush x:Key="BrushGood" Color="#4CAF50"/>
        <SolidColorBrush x:Key="BrushWarn" Color="#FFC107"/>
        <SolidColorBrush x:Key="BrushBad" Color="#F44336"/>

        <Style x:Key="TabToggleButtonStyle" TargetType="RadioButton">
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="Foreground" Value="{StaticResource BrushTextSecondary}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Bg" CornerRadius="8" Background="Transparent" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Bg" Property="Background" Value="{StaticResource BrushPanelBackground}"/>
                                <Setter Property="Foreground" Value="{StaticResource BrushTextPrimary}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="UsageProgressBarStyle" TargetType="ProgressBar">
            <Setter Property="Height" Value="8"/>
            <Setter Property="Minimum" Value="0"/>
            <Setter Property="Maximum" Value="100"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Grid x:Name="TemplateRoot">
                            <Border Background="{StaticResource BrushTrackBackground}" CornerRadius="4"/>
                            <Border x:Name="PART_Track" Background="Transparent" CornerRadius="4"/>
                            <Border x:Name="PART_Indicator"
                                    Background="{TemplateBinding Foreground}"
                                    CornerRadius="4"
                                    HorizontalAlignment="Left"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Application.Resources>
</Application>
